{
  "expo": {
    "name": "Gestao Ativos",
    "slug": "gestao-ativos",
    "version": "2.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "gestaoativos",
    "platforms": [
      "android"
    ],
    "plugins": [
      [
        "./plugins/with-cielo-smart.cjs",
        {
          "minSdkVersion": 23
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permitir que o Gestao Ativos use a camera para anexar fotos as tarefas."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permitir que o Gestao Ativos capture a localizacao ao concluir a coleta."
        }
      ]
    ],
    "splash": {
      "backgroundColor": "#111827",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "br.com.gestaoativos.app",
      "versionCode": 22,
      "icon": "./assets/icon.png",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "extra": {
      "base44AppId": "69b984ecbe7402af99e141a5",
      "base44AppBaseUrl": "https://base44.app",
      "base44FunctionsVersion": "v3",
      "eas": {
        "projectId": "ecdbf55e-3968-4428-abc0-cc214cf75d4b"
      }
    },
    "owner": "felpszap"
  }
}
